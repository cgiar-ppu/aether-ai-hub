# CGIAR AI Co-Scientist Backend Configuration
# Copy this file to .env and fill in the values

COSCIENTIST_AWS_REGION=eu-west-1
COSCIENTIST_COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
COSCIENTIST_COGNITO_CLIENT_ID=your-cognito-client-id
COSCIENTIST_COGNITO_JWKS_URL=
COSCIENTIST_DYNAMODB_SESSIONS_TABLE=co-scientist-sessions
COSCIENTIST_DYNAMODB_WORKFLOWS_TABLE=co-scientist-workflows
COSCIENTIST_S3_BUCKET_USER_DATA=co-scientist-user-data-ACCOUNT_ID
COSCIENTIST_AGENT_SERVICE_BASE_URL=http://localhost:7777
COSCIENTIST_LAMBDA_PROVISION_FUNCTION=co-scientist-provision
COSCIENTIST_LAMBDA_DEPROVISION_FUNCTION=co-scientist-deprovision
COSCIENTIST_LAMBDA_STATUS_FUNCTION=co-scientist-status
COSCIENTIST_CORS_ORIGINS=["https://www.ai-co-scientist-app.synapsis-analytics.com","https://ai-co-scientist-app.synapsis-analytics.com","http://localhost:5173","http://localhost:3000"]
COSCIENTIST_AMPLIFY_APP_URL=https://www.ai-co-scientist-app.synapsis-analytics.com
